{
  "name": "prestashop/lowestshipping",
  "description": "Lowest shipping estimate on the product page for PrestaShop 9",
  "license": "MIT",
  "authors": [
    {
      "name": "Maxsoft"
    }
  ],
  "autoload": {
    "psr-4": {
      "PrestaShop\\Module\\Lowestshipping\\": "src/"
    }
  },
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.48",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^9.5 || ^10.0",
    "prestashop/php-dev-tools": "^5.0"
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit -c phpunit.xml.dist",
    "cs-check": "php-cs-fixer fix --dry-run --diff --verbose --config=../.php-cs-fixer.dist.php",
    "cs-fix": "php-cs-fixer fix --verbose --config=../.php-cs-fixer.dist.php",
    "phpstan": "phpstan analyse -c phpstan.neon --memory-limit=512M",
    "phpstan:init": "prestashop-coding-standards phpstan:init --dest ."
  },
  "config": {
    "preferred-install": "dist",
    "prepend-autoloader": false,
    "sort-packages": true
  },
  "type": "prestashop-module"
}

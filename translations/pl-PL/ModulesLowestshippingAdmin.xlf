<?xml version="1.0" encoding="UTF-8"?>
<xliff xmlns="urn:oasis:names:tc:xliff:document:1.2" version="1.2">
  <file original="ModulesLowestshippingAdmin" source-language="en-US" target-language="pl-PL" datatype="plaintext">
    <body>
      <trans-unit id="lowestshipping.admin.display_name">
        <source>Lowest shipping estimate</source>
        <target>Szacunek najtańszej dostawy</target>
      </trans-unit>
      <trans-unit id="lowestshipping.admin.description">
        <source>Shows the lowest deliverable shipping cost for the current product using the shop’s native carrier and cart rules logic.</source>
        <target>Pokazuje najniższy możliwy koszt dostawy z użyciem natywnych przewoźników i reguł koszyka PrestaShop.</target>
      </trans-unit>
      <trans-unit id="lowestshipping.admin.uninstall">
        <source>Uninstall this module?</source>
        <target>Odinstalować ten moduł?</target>
      </trans-unit>
      <trans-unit id="lowestshipping.admin.no_symfony">
        <source>Symfony container is not available.</source>
        <target>Kontener Symfony jest niedostępny.</target>
      </trans-unit>
      <trans-unit id="lowestshipping.admin.settings_title">
        <source>Lowest shipping on product page</source>
        <target>Najtańsza dostawa na karcie produktu</target>
      </trans-unit>
      <trans-unit id="lowestshipping.admin.settings_updated">
        <source>Settings updated.</source>
        <target>Ustawienia zapisane.</target>
      </trans-unit>
      <trans-unit id="lowestshipping.admin.default_country_shipping">
        <source>Default country for shipping estimate</source>
        <target>Domyślny kraj do szacunku dostawy</target>
      </trans-unit>
      <trans-unit id="lowestshipping.admin.default_country_shipping_help">
        <source>Used for guests and for customers without a delivery address.</source>
        <target>Dla gości oraz klientów bez zapisanego adresu dostawy.</target>
      </trans-unit>
      <trans-unit id="lowestshipping.admin.show_cost_tax">
        <source>Show cost including tax</source>
        <target>Pokazuj koszt z podatkiem</target>
      </trans-unit>
      <trans-unit id="lowestshipping.admin.price_prefix">
        <source>Price prefix</source>
        <target>Prefiks przed ceną</target>
      </trans-unit>
      <trans-unit id="lowestshipping.admin.price_prefix_help">
        <source>Example: "From " or "Cheapest delivery: "</source>
        <target>Przykład: „Od ” lub „Najtańsza dostawa: ”</target>
      </trans-unit>
      <trans-unit id="lowestshipping.admin.extra_under_price">
        <source>Extra text under the price</source>
        <target>Dodatkowy opis pod ceną</target>
      </trans-unit>
      <trans-unit id="lowestshipping.admin.extra_under_price_help">
        <source>Optional note shown below the shipping price on the product page.</source>
        <target>Opcjonalna notka pod ceną dostawy na stronie produktu.</target>
      </trans-unit>
      <trans-unit id="lowestshipping.admin.show_on_product">
        <source>Show block on product page</source>
        <target>Włącz na karcie produktu</target>
      </trans-unit>
      <trans-unit id="lowestshipping.admin.show_on_product_help">
        <source>Turn off to hide the estimate everywhere on product pages.</source>
        <target>Wyłączenie ukrywa blok na wszystkich kartach produktów.</target>
      </trans-unit>
      <trans-unit id="lowestshipping.admin.error_select_country">
        <source>Please select a default country.</source>
        <target>Wybierz domyślny kraj.</target>
      </trans-unit>
      <trans-unit id="lowestshipping.admin.error_invalid_payload">
        <source>The submitted data is invalid.</source>
        <target>Przesłane dane są nieprawidłowe.</target>
      </trans-unit>
    </body>
  </file>
</xliff>
